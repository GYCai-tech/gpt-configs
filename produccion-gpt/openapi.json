{
  "openapi": "3.0.3",
  "info": {
    "title": "GYC Producción DW API",
    "description": "Consulta las vistas analíticas de producción de Gómez y Crespo (Data Warehouse PostgreSQL).",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "https://werner-mammalogical-unbeautifully.ngrok-free.dev"
    }
  ],
  "paths": {
    "/query-dw": {
      "post": {
        "operationId": "consultarDW",
        "summary": "Ejecutar consulta SQL en el Data Warehouse de producción de GYC",
        "description": "Recibe una consulta SELECT y la ejecuta contra el schema analytics de gyc_analytics (PostgreSQL). Devuelve hasta 500 filas.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["sql"],
                "properties": {
                  "sql": {
                    "type": "string",
                    "description": "Consulta SQL SELECT válida para PostgreSQL. Usar schema analytics (analytics.v_*) o core (core.fact_*, core.dim_*)."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resultados de la consulta",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "columns": { "type": "array", "items": { "type": "string" } },
                    "rows": { "type": "array", "items": { "type": "object" } },
                    "row_count": { "type": "integer" },
                    "truncated": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
